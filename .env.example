# A2A MCP Reference Agent Environment Configuration

# ---------------------------------------------------------------------------
# Inference (set ONE of the two — OpenRouter is preferred)
# ---------------------------------------------------------------------------

# OpenRouter — single key, works for DeepSeek, Kimi, GLM, OpenAI, Anthropic, …
# Get one at https://openrouter.ai/keys.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Or, direct DeepSeek (skip OPENROUTER_API_KEY above and uncomment these):
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Model id. On OpenRouter use the namespaced form (e.g. `deepseek/deepseek-v4-flash`);
# on the direct DeepSeek API use the bare form (e.g. `deepseek-v4-flash`).
DEEPSEEK_MODEL=deepseek/deepseek-v4-flash

# A2A Server Configuration
A2A_HOST=0.0.0.0
A2A_PORT=8000
A2A_DEBUG=false

# Gradio UI Configuration
GRADIO_HOST=0.0.0.0
GRADIO_PORT=7860
GRADIO_SHARE=false

# MCP Server Configuration
MCP_TIMEOUT=30
MCP_MAX_RETRIES=3

# Mock Mode (for testing without real API keys)
MOCK_MODE=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Optional: GitHub Token (for GitHub MCP server)
GITHUB_TOKEN=your_github_token_here

# Optional: Search API Keys
SERPER_API_KEY=your_serper_api_key_here
